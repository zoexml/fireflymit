{
  "name": "@fireflymit/ui",
  "version": "0.1.2",
  "description": "UI Components built with Vue3 - Element Plus",
  "author": "joet桀",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zoexml/fireflymit"
  },
  "keywords": [
    "ui",
    "vue",
    "vue3",
    "components"
  ],
  "sideEffects": [
    "*.css",
    "dist/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/es/index.d.ts",
      "import": "./dist/es/index.mjs",
      "require": "./dist/lib/index.js"
    },
    "./resolver": {
      "types": "./dist/es/resolver.d.ts",
      "import": "./dist/es/resolver.mjs",
      "require": "./dist/lib/resolver.js"
    },
    "./dist/index.css": "./dist/index.css",
    "./es/components/*": {
      "types": "./dist/es/components/*/index.d.ts",
      "import": "./dist/es/components/*/index.mjs",
      "require": "./dist/lib/components/*/index.js"
    },
    "./lib/components/*": {
      "types": "./dist/lib/components/*/index.d.ts",
      "import": "./dist/es/components/*/index.mjs",
      "require": "./dist/lib/components/*/index.js"
    },
    "./lib/*": "./dist/lib/*",
    "./es/*": "./dist/es/*"
  },
  "main": "dist/lib/index.js",
  "module": "dist/es/index.mjs",
  "types": "dist/es/index.d.ts",
  "style": "dist/index.css",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "scripts": {
    "clean": "rimraf .turbo dist",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:bench": "vitest bench",
    "check-types": "vue-tsc --noEmit --project tsconfig.json",
    "build": "pnpm run clean && vite build",
    "release": "pnpm publish --no-git-checks"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@vueuse/core": "^14.1.0",
    "element-plus": "^2.11.9",
    "vue": "^3.5.21"
  },
  "dependencies": {
    "@fireflymit/hooks": "workspace:*",
    "@fireflymit/utils": "workspace:*",
    "@iconify/vue": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "sass": "^1.93.2",
    "unplugin-auto-import": "^20.2.0",
    "unplugin-vue-components": "^29.1.0",
    "vitest": "^4.0.14",
    "vue": "^3.5.21"
  }
}
