{
  "name": "@fireflymit/utils",
  "type": "module",
  "version": "0.0.3",
  "description": "@fireflymit utils library",
  "repository": {
    "type": "git",
    "url": "https://github.com/zoexml/fireflymit"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "rimraf .turbo node_modules dist",
    "check-types": "tsc --noEmit --project tsconfig.json",
    "build": "unbuild",
    "release": "pnpm publish --no-git-checks"
  },
  "devDependencies": {}
}
