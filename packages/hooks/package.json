{
  "name": "@fireflymit/hooks",
  "type": "module",
  "version": "0.0.2",
  "description": "@fireflymit hooks & directives library",
  "repository": {
    "type": "git",
    "url": "https://github.com/zoexml/fireflymit"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "rimraf .turbo node_modules dist",
    "check-types": "tsc --noEmit --project tsconfig.json",
    "build": "unbuild",
    "release": "pnpm publish --no-git-checks"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@fireflymit/utils": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.1.2",
    "typescript": "5.9.3",
    "unbuild": "^3.6.1",
    "vue": "^3.5.21"
  }
}
