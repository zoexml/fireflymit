    "vue-draggable-plus": "^0.6.0",
    "vue-i18n": "^11.1.10",
    "vue-json-pretty": "^2.5.0",
    "vue-router": "^5.0.7",
    "vue-web-terminal": "^3.4.1",
    "vue3-cron-plus": "^0.1.9",
    "vuedraggable": "^2.24.3",
    "xgplayer": "^3.0.20",
    "xlsx": "^0.18.5"
