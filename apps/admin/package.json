    "codemirror-editor-vue3": "^2.8.0",
    "crypto-js": "^4.2.0",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.3",
    "echarts": "^6.0.0",
    "element-plus": "~2.13.7",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "highlight.js": "^11.11.1",
    "js-beautify": "^1.15.4",
    "markdown-it": "^14.1.0",
    "markdown-it-highlightjs": "^4.3.0",
    "mitt": "^3.0.1",
